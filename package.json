{
    "name": "hdb-job-planner",
    "version": "0.1.0",
    "private": true,
    "main": "electron/main.js",
    "scripts": {
        "dev": "next dev",
        "build": "npx prisma generate && next build",
        "start": "next start",
        "lint": "next lint",
        "postinstall": "prisma generate",
        "electron:dev": "concurrently \"npm run dev\" \"wait-on tcp:3000 && electron .\"",
        "electron:build": "npm run build && electron-builder",
        "electron:pack": "electron-builder --dir"
    },
    "dependencies": {
        "@ducanh2912/next-pwa": "^10.2.9",
        "@google/genai": "^2.5.0",
        "@prisma/client": "^5.22.0",
        "@react-pdf/renderer": "^4.3.2",
        "@types/leaflet": "^1.9.21",
        "@vercel/analytics": "^2.0.1",
        "@vercel/speed-insights": "^1.3.1",
        "bcryptjs": "^3.0.3",
        "clsx": "^2.1.0",
        "date-fns": "^3.6.0",
        "date-fns-tz": "^3.2.0",
        "echarts": "^6.1.0",
        "echarts-for-react": "^3.0.6",
        "html5-qrcode": "^2.3.8",
        "idb": "^8.0.0",
        "jose": "^6.2.3",
        "leaflet": "^1.9.4",
        "lucide-react": "^0.344.0",
        "next": "14.1.0",
        "next-themes": "^0.4.6",
        "node-cron": "^4.2.1",
        "prismjs": "^1.30.0",
        "qrcode.react": "^4.2.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-leaflet": "^4.2.1",
        "react-markdown": "^10.1.0",
        "react-onesignal": "^3.5.1",
        "react-simple-code-editor": "^0.14.1",
        "swr": "^2.4.1",
        "tailwind-merge": "^2.2.1",
        "tailwindcss-animate": "^1.0.7",
        "uuid": "^9.0.1",
        "xlsx": "^0.18.5",
        "zod": "^4.4.3",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.60.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/node": "20.19.35",
        "@types/node-cron": "^3.0.11",
        "@types/prismjs": "^1.26.6",
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@types/uuid": "^9.0.7",
        "autoprefixer": "^10.0.1",
        "concurrently": "^9.2.3",
        "electron": "^41.7.1",
        "electron-builder": "^26.15.3",
        "eslint": "^8",
        "eslint-config-next": "14.1.0",
        "portfinder": "^1.0.38",
        "postcss": "^8",
        "prisma": "^5.22.0",
        "tailwindcss": "^3.3.0",
        "typescript": "^5",
        "wait-on": "^9.0.10"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@prisma/client",
            "@prisma/engines",
            "prisma",
            "unrs-resolver"
        ]
    },
    "build": {
        "appId": "com.hdb.jobplanner",
        "productName": "HDB Job Planner",
        "directories": {
            "output": "dist_electron"
        },
        "files": [
            "electron/**/*",
            ".next/**/*",
            "public/**/*",
            "node_modules/**/*",
            "package.json",
            "prisma/**/*"
        ],
        "extraResources": [
            "prisma/schema.prisma"
        ],
        "asarUnpack": [
            "**/.prisma/**",
            "**/@prisma/**"
        ],
        "asar": false,
        "win": {
            "target": [
                "nsis"
            ],
            "icon": "public/images/android/launchericon-512x512.png"
        }
    }
}
