generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id                      String              @id @default(cuid())
  codigoProyecto          String?             @unique
  nombre                  String
  activo                  Boolean             @default(true)
  noEnMetricas            Boolean             @default(false)
  categoria               String?
  tipoActividad           String?
  observaciones           String?
  horasEstimadas          Int                 @default(0)
  horasConsumidas         Int                 @default(0)
  cliente                 String? // Keeping this for legacy text
  clientId                String?
  client                  HdbClient?          @relation(fields: [clientId], references: [id])
  responsable             String? // Legacy name field
  responsableId           String?
  responsableUser         Operator?           @relation("ProjectResponsable", fields: [responsableId], references: [id])
  tags                    Json                @default("[]") // Technical tags: "Montaje", "Tendido", etc.
  estado                  String              @default("activo") // por_hacer | planificado | activo | en_riesgo | atrasado | finalizado
  fechaInicio             String?
  fechaFin                String?
  finalizadoConPendientes Boolean             @default(false)
  publicToken             String?             @unique
  pendientesSnapshot      Json? // Snapshot of incomplete items if forced finish
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @default(now()) @updatedAt
  clientDelays            ClientDelay[]
  timeEntries             TimeEntry[]
  checklistItems          ChecklistItem[]
  logs                    ProjectLog[]
  generarOS               Boolean             @default(false)
  aprovisionamiento       Boolean             @default(false)
  ordenesServicio         OrdenServicio[]
  encuestas               EncuestaServicio[]
  materialesProyecto      MaterialProyecto[]
  fichadas                Fichada[]
  // Geofence & QR data
  geofenceLat             Float?
  geofenceLng             Float?
  geofenceRadius          Float? // radius in meters
  qrToken                 String? // current token signature for QR validation
  fichajeHabilitado       Boolean             @default(false)
  proyectoFijo            Boolean             @default(false)
  qrHistory               QrTokenHistory[]
  toolMovements           ToolMovement[]
  documentChecklists      DocumentChecklist[]
  tareas                  Tarea[]

  @@index([qrToken])
}

model QrTokenHistory {
  id             String   @id @default(cuid())
  token          String   @unique
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  isCompanyToken Boolean  @default(false)
  replacedAt     DateTime @default(now())

  @@index([token])
  @@index([projectId])
}

model ProjectLog {
  id             String    @id @default(cuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fecha          String // YYYY-MM-DD
  responsable    String
  responsableId  String?
  responsableRel Operator? @relation("ProjectLogResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  observacion    String
  categoria      String    @default("Nota") // Reporte | Nota | Bloqueante | Consulta
  createdAt      DateTime  @default(now())

  @@index([projectId])
  @@index([fecha])
}

model ChecklistItem {
  id                    String   @id @default(cuid())
  projectId             String
  project               Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tag                   String
  description           String
  completed             Boolean  @default(false)
  excluded              Boolean  @default(false)
  confirmedBySupervisor Boolean  @default(false)
  pendingChange         Boolean  @default(false) // Request to unmark or similar
  justification         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([projectId])
}

model ClientDelay {
  id              String    @id @default(cuid())
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fecha           String // YYYY-MM-DD
  hora            String // HH:mm
  operador        String // Operador interno que registra
  operadorId      String?
  operadorRel     Operator? @relation("ClientDelayOperador", fields: [operadorId], references: [id], onDelete: SetNull)
  area            String // Control Documentario, Calidad, Compras, IT
  responsableArea String? // Nombre del responsable del área (opcional)
  motivo          String // Motivo de la demora
  duracion        Float // Tiempo demorado en horas
  createdAt       DateTime  @default(now())

  @@index([projectId])
}

model Operator {
  id                        String                      @id @default(cuid())
  nombreCompleto            String
  activo                    Boolean                     @default(true)
  enVacaciones              Boolean                     @default(false)
  etiquetas                 Json // Now using native Json type
  pin                       String                      @default("1234")
  role                      String                      @default("operador") // operador | supervisor | admin | vendedor | qa
  dni                       String?
  posicion                  String? // e.g. "Director", "QA Manager", "Gerente"
  responsibleProjects       Project[]                   @relation("ProjectResponsable")
  createdAt                 DateTime                    @default(now())
  timeEntries               TimeEntry[]
  notifications             Notification[]
  ordenesServicio           OrdenServicioOperador[]
  fichadas                  Fichada[]
  toolMovements             ToolMovement[]
  primaryDeviceId           String?
  OSDocumentAcknowledgement OSDocumentAcknowledgement[]
  competencies              TechnicianCompetency[]
  trainings                 TechnicianTraining[]
  externalCertificates      ExternalCertificate[]
  safetyAudits              SafetyAudit[]
  sugerencias_creadas       Sugerencia[]                @relation("SugerenciaAutor")
  sugerencias_asignadas     Sugerencia[]                @relation("SugerenciaResponsable")
  acciones_mejora           AccionMejora[]
  ncRegistradas             NoConformidad[]             @relation("NCResponsableRegistro")
  ncTratadas                NoConformidad[]             @relation("NCResponsableTratamiento")
  analisisCausaRaiz         AnalisisCausaRaiz[]
  verificacionesEficacia    VerificacionEficacia[]
  tareasInvolucradas        TareaInvolucrado[]
  tareasComentarios         TareaComentario[]

  // Nuevas relaciones (Auditoria DB)
  clientDelays             ClientDelay[]     @relation("ClientDelayOperador")
  projectLogs              ProjectLog[]      @relation("ProjectLogResponsable")
  timeEntriesApproved      TimeEntry[]       @relation("TimeEntryApprover")
  documentVersionsAuthored DocumentVersion[] @relation("DocVersionAutor")
  documentVersionsApproved DocumentVersion[] @relation("DocVersionAprobador")
  documentPrints           DocumentPrint[]

  // OKR / KPI
  okrsResponsable    Okr[]           @relation("OkrResponsable")
  kpisResponsable    Kpi[]           @relation("KpiResponsableCarga")
  planesAccionKpi    PlanAccionKpi[] @relation("PlanAccionKpiResponsable")
  datasetsResponsable Dataset[]      @relation("DatasetResponsable")
}

model FavoriteBlock {
  id            String  @id @default(cuid())
  name          String
  projectId     String?
  projectName   String?
  startTime     String?
  endTime       String?
  note          String?
  operatorIds   Json? // Now using native Json type
  operatorNames Json? // Now using native Json type
  isNoteOnly    Boolean @default(false)
}

model Planning {
  id        String   @id @default(cuid())
  fecha     String   @unique // YYYY-MM-DD
  blocks    Json // Now using native Json type
  createdAt DateTime @default(now())
}

model HdbClient {
  id        String    @id @default(cuid())
  nombre    String
  email     String?
  telefono  String?
  direccion String?
  activo    Boolean   @default(true)
  projects  Project[]
  createdAt DateTime  @default(now())
}

model TimeEntry {
  id                      String    @id @default(cuid())
  operatorId              String
  operator                Operator  @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  projectId               String?
  project                 Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fecha                   String // YYYY-MM-DD
  horaIngreso             String? // HH:mm
  horaEgreso              String? // HH:mm
  horasTrabajadas         Float     @default(0)
  estadoConfirmado        Boolean   @default(false)
  confirmadoPorSupervisor String?
  isExtra                 Boolean   @default(false)
  isDevolucion            Boolean   @default(false)
  descripcionDevolucion   String?   @db.Text
  causaRegistro           String? // "Falta", "Permiso", "Carpeta Médica", etc. (from ConfigOption CAUSA_REGISTRO)
  // Legacy punch-in fields (kept for data integrity, new punch-ins go to Fichada table)
  deviceId                String?
  latitude                Float?
  longitude               Float?
  qrValidated             Boolean   @default(false)
  validationFlags         Json?
  isSuspicious            Boolean   @default(false)
  isOfflinePending        Boolean   @default(false)
  status                  String    @default("AUTO_APPROVED")
  score                   Int       @default(0)
  riskLevel               String    @default("OK")
  approvedById            String?
  approvedBy              Operator? @relation("TimeEntryApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedAt              DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([projectId])
  @@index([operatorId])
}

model Notification {
  id             String    @id @default(cuid())
  operatorId     String? // If null and forSupervisors=true, it goes to all supervisors
  operator       Operator? @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  forSupervisors Boolean   @default(false)
  title          String
  message        String
  type           String // TIME_EDIT_REQUEST, PLANNING_ASSIGNMENT
  relatedId      String? // ID of TimeEntry or Planning block
  metadata       Json? // To store requested modifications or planning block details
  read           Boolean   @default(false)
  createdAt      DateTime  @default(now())

  @@index([operatorId])
  @@index([createdAt])
}

model ProjectTag {
  id             String                 @id @default(cuid())
  name           String                 @unique
  active         Boolean                @default(true)
  impactsMetrics Boolean                @default(false)
  checklists     TagChecklistItem[]
  templates      TagChecklistTemplate[]
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
}

model TagChecklistItem {
  id          String     @id @default(cuid())
  tagId       String
  tag         ProjectTag @relation(fields: [tagId], references: [id], onDelete: Cascade)
  description String
  active      Boolean    @default(true)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tagId])
}

model ConfigOption {
  id        String   @id @default(cuid())
  category  String // e.g "AREA_DEMORA", "MOTIVO_DEMORA", "CATEGORIA", "TIPO_ACTIVIDAD"
  value     String
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model IdempotencyKey {
  key       String   @id
  response  Json?
  createdAt DateTime @default(now())
}

model SystemSetting {
  id                    String  @id @default("default")
  dailyReminderEnabled  Boolean @default(false)
  dailyReminderTime     String  @default("16:45")
  valorManoObra         Float   @default(0)
  companyGeofenceLat    Float?
  companyGeofenceLng    Float?
  companyGeofenceRadius Float?
  companyQrToken        String?
  fichajeHabilitado     Boolean @default(false)

  // Configuración de Notificaciones
  daysWithoutHoursThreshold Int @default(5)
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  userName  String?
  action    String // CREATE | UPDATE | DELETE | APPROVE | REJECT
  entity    String // TIME_ENTRY | PROJECT | USER | SETTING | etc
  entityId  String?
  timestamp DateTime @default(now())
  oldValue  Json?
  newValue  Json?
  metadata  Json? // { deviceId, location, ip, etc }

  @@index([entity])
  @@index([userId])
  @@index([timestamp])
}

model OrdenServicio {
  id            String                  @id @default(cuid())
  codigoOS      String?                 @unique
  projectId     String
  project       Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  reporte       String                  @db.Text
  comentario    String?                 @db.Text
  notaInterna   String?                 @db.Text
  fechaCreacion DateTime                @default(now())
  estado        String                  @default("pendiente") // pendiente | firmada | cobrada | pagada | cancelada
  linkPublico   String                  @unique @default(uuid())
  materiales    OrdenServicioMaterial[]
  operadores    OrdenServicioOperador[]
  firma         OrdenServicioFirma?
  encuesta      EncuestaServicio?

  // Cobro
  cobroGenerado            Boolean   @default(false)
  cobroValorManoObra       Float?
  cobroDescuentoPorcentaje Float?
  cobroAplicarIva          Boolean   @default(true)
  cobroTotalFinal          Float?
  cobroObservaciones       String?   @db.Text
  cobroCondicionPago       String?
  cobroOtrosConceptos      Json? // [{ nombre: string, precio: number }]
  cobroFechaGeneracion     DateTime?
  cobroFechaPago           DateTime? // Fecha de pago real o estimada

  // QMS Integration
  documentosRequeridos OrdenServicioDocumento[]
  checklists           OSChecklist[]

  // Rework tracking
  esReTrabajo     Boolean @default(false)
  ordenOriginalId String?

  @@index([projectId])
}

model OrdenServicioMaterial {
  id                 String            @id @default(cuid())
  ordenServicioId    String
  ordenServicio      OrdenServicio     @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)
  material           String
  codigo             String?
  cantidad           Float
  unidadMedida       String
  precioUnitario     Float?
  materialProyectoId String?           @map("material_proyecto_id")
  materialProyecto   MaterialProyecto? @relation(fields: [materialProyectoId], references: [id], onDelete: SetNull)

  @@index([ordenServicioId])
  @@index([codigo])
}

model OrdenServicioOperador {
  id              String        @id @default(cuid())
  ordenServicioId String
  ordenServicio   OrdenServicio @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)
  operadorId      String
  operador        Operator      @relation(fields: [operadorId], references: [id], onDelete: Cascade)
  horas           Float
  isExtra         Boolean       @default(false)

  @@index([ordenServicioId])
  @@index([operadorId])
}

model OrdenServicioFirma {
  id              String        @id @default(cuid())
  ordenServicioId String        @unique
  ordenServicio   OrdenServicio @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)
  nombre          String
  dni             String
  firmaImagen     String        @db.Text
  fechaFirma      DateTime      @default(now())

  @@index([ordenServicioId])
}

model EncuestaServicio {
  id              String        @id @default(cuid())
  ordenServicioId String        @unique
  ordenServicio   OrdenServicio @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)
  proyectoId      String
  project         Project       @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  fecha           DateTime      @default(now())
  atencion        Int // 1-10
  calidad         Int // 1-10
  tiempo          Int // 1-10
  nps             Int // 0-10
  comentario      String?       @db.Text

  @@index([proyectoId])
  @@index([fecha])
}

model MaterialProyecto {
  id                        String                  @id @default(cuid())
  proyectoId                String
  proyecto                  Project                 @relation(fields: [proyectoId], references: [id], onDelete: Cascade)
  nombre                    String
  codigo                    String?
  unidad                    String                  @default("unidad")
  cantidadSolicitada        Float                   @default(0)
  cantidadDisponible        Float                   @default(0)
  cantidadEntregada         Float                   @default(0)
  estado                    String                  @default("material_cargado")
  // material_cargado | material_entregado | uso_confirmado | pendiente_devolucion | cerrado_ok | cerrado_con_reserva
  createdAt                 DateTime                @default(now())
  precioVenta               Float?
  usos                      MaterialUso[]
  devoluciones              MaterialDevolucion[]
  ordenesServicioMateriales OrdenServicioMaterial[]

  @@index([proyectoId])
  @@index([codigo])
}

model MaterialMaestro {
  codigo      String   @id
  nombre      String
  unidad      String
  precioVenta Float?
  costo       Float?
  updatedAt   DateTime @updatedAt
}

model MaterialUso {
  id                String           @id @default(cuid())
  materialId        String
  material          MaterialProyecto @relation(fields: [materialId], references: [id], onDelete: Cascade)
  ordenServicioId   String? // null si es uso directo sin OS
  cantidadUtilizada Float
  operadorNombre    String
  createdAt         DateTime         @default(now())

  @@index([materialId])
}

model MaterialDevolucion {
  id                String           @id @default(cuid())
  materialId        String
  material          MaterialProyecto @relation(fields: [materialId], references: [id], onDelete: Cascade)
  cantidadADevolver Float
  estado            String           @default("pendiente")
  // pendiente | cerrado_ok | cerrado_con_reserva | delegacion_pendiente | delegacion_rechazada
  comentario        String?          @db.Text
  confirmadoPor     String?
  fechaConfirm      DateTime?
  createdAt         DateTime         @default(now())

  // Delegacion
  delegadoAId       String?
  delegadoANombre   String?
  firmaDelegacion   String? @db.Text
  delegadoPorId     String?
  delegadoPorNombre String?

  @@index([materialId])
}

model Fichada {
  id              String   @id @default(cuid())
  operatorId      String
  operator        Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  projectId       String?
  project         Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fecha           String // YYYY-MM-DD
  horaIngreso     String? // HH:mm
  horaEgreso      String? // HH:mm
  horasTrabajadas Float    @default(0)

  deviceId         String?
  latitude         Float?
  longitude        Float?
  qrValidated      Boolean @default(false)
  validationFlags  Json?
  latitudeEgreso   Float?
  longitudeEgreso  Float?
  isSuspicious     Boolean @default(false)
  isOfflinePending Boolean @default(false)

  status    String @default("AUTO_APPROVED")
  score     Int    @default(0)
  riskLevel String @default("OK")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fecha])
  @@index([projectId])
  @@index([operatorId])
}

// ═══════════════════════════════════════════════════════
// HERRAMIENTAS Y CARROS (nuevo modelo unificado)
// ═══════════════════════════════════════════════════════

model Tool {
  id          String  @id // 8-char alphanumeric unique
  nombre      String
  marca       String?
  descripcion String? @db.Text
  tipo        String // MANUAL | ELECTRICA | NEUMATICA | HIDRAULICA | CARRO
  subtipo     String? // CORTE | MEDICION | AJUSTE | PERFORACION | SUJECION
  rubro       String? // ELECTRICIDAD | OBRA | TALLER | IT

  // Control / Verificación
  controlActivo         Boolean   @default(false)
  periodoControl        Int       @default(60) // días (30, 60, 90, 180, 365)
  ultimoControlFecha    DateTime?
  ultimoControlOperador String? // nombre snapshot
  estadoHerramienta     String? // APROBADA | RECHAZADA | null

  // Asignación a carro (self-referential)
  carroId      String?
  carro        Tool?   @relation("ToolEnCarro", fields: [carroId], references: [id], onDelete: SetNull)
  herramientas Tool[]  @relation("ToolEnCarro")

  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  verificaciones       ToolVerification[]
  cartMovementsAsCarro ToolMovement[]
  cartMovementItems    ToolMovementItem[] @relation("ToolMovementItemRef")

  @@index([tipo])
  @@index([carroId])
  @@index([controlActivo])
}

model ToolVerification {
  id             String   @id @default(cuid())
  toolId         String
  tool           Tool     @relation(fields: [toolId], references: [id], onDelete: Cascade)
  operadorId     String
  operadorNombre String
  estado         String // APROBADA | RECHAZADA
  fecha          DateTime @default(now())

  @@index([toolId])
  @@index([fecha])
}

model ToolMovement {
  id         String   @id @default(uuid())
  carroId    String
  carro      Tool     @relation(fields: [carroId], references: [id], onDelete: Restrict)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Restrict)

  fechaSalida     DateTime  @default(now())
  fechaDevolucion DateTime?
  estado          String    @default("ACTIVO") // ACTIVO | COMPLETADO

  items ToolMovementItem[]
}

model ToolMovementItem {
  id         String       @id @default(uuid())
  movementId String
  movement   ToolMovement @relation(fields: [movementId], references: [id], onDelete: Cascade)

  toolId       String? // referencia a Tool registrada (null si es adicional efímera)
  tool         Tool?   @relation("ToolMovementItemRef", fields: [toolId], references: [id], onDelete: SetNull)
  nombre       String // snapshot del nombre
  cantidad     Int     @default(1)
  isAdditional Boolean @default(false)

  // Status at checkout (salida)
  presentAtOut Boolean @default(true)
  cantidadOut  Int     @default(0)

  // Status at checkin (devolucion)
  presentAtIn Boolean?
  cantidadIn  Int?
}

// ═══════════════════════════════════════════════════════════════════════════════
// CALIDAD Y CONTROL DOCUMENTAL — QMS / ISO 9001
// ═══════════════════════════════════════════════════════════════════════════════

model ControlledDocument {
  id               String @id @default(cuid())
  codigoDocumental String @unique // PR-TEC-001, IN-SEG-003, etc.
  titulo           String
  tipoDocumento    String // Procedimiento | Instructivo | Manual técnico | Formulario | Política | Norma de seguridad | Checklist estándar | Protocolo | Especificación técnica | Certificado
  area             String // Producción | Calidad | Seguridad | IT | RRHH | etc.
  estado           String @default("borrador") // borrador | en_revision | vigente | obsoleto

  // Versión actual (snapshot para consulta rápida)
  versionMayor Int @default(1)
  versionMenor Int @default(0)

  // Descripción larga
  descripcion String? @db.Text

  // Fechas
  fechaEmision    DateTime  @default(now())
  fechaRevision   DateTime?
  proximaRevision DateTime?

  // Responsables
  responsableId     String?
  responsableNombre String? // Snapshot del nombre
  revisadorId       String?
  revisadorNombre   String?
  aprobadorId       String?
  aprobadorNombre   String? // Snapshot del nombre

  // Configuración
  requiereConfirmacionLectura Boolean @default(false)
  requiereCapacitacion        Boolean @default(false)
  nivelCriticidad             String  @default("media") // baja | media | alta | critica
  validezMeses                Int? // Periodo de validez de la capacitación en meses (opcional)

  // Trazabilidad
  documentoReemplazadoId  String?
  documentoReemplazado    ControlledDocument?  @relation("DocumentReplace", fields: [documentoReemplazadoId], references: [id], onDelete: SetNull)
  documentosReemplazantes ControlledDocument[] @relation("DocumentReplace")
  motivoCambio            String?              @db.Text
  hashDocumental          String? // SHA-256 del archivo vigente

  // Metadata
  tags          Json    @default("[]") // Array de strings
  observaciones String? @db.Text
  workflowState Json? // Workflow de firmas y acuerdos

  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  createdBy     String? // userId
  createdByName String? // Snapshot

  // Relations
  versions           DocumentVersion[]
  readConfirmations  DocumentReadConfirmation[]
  alerts             DocumentAlert[]
  documentChecklists DocumentChecklist[]
  prints             DocumentPrint[]

  // OS Integrations
  applicabilityRules    DocumentApplicabilityRule[]
  osAssignments         OrdenServicioDocumento[]
  competencies          TechnicianCompetency[]
  trainings             TechnicianTraining[]
  documentacionAfectada DocumentacionAfectada[]

  @@index([tipoDocumento])
  @@index([area])
  @@index([estado])
  @@index([nivelCriticidad])
  @@index([proximaRevision])
}

model DocumentVersion {
  id         String             @id @default(cuid())
  documentId String
  document   ControlledDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  versionMayor Int
  versionMenor Int
  versionLabel String // "1.0", "1.1", "2.0"

  estado String @default("borrador") // borrador | en_revision | vigente | obsoleto

  // Autoría y aprobación
  autorId         String?
  autor           Operator? @relation("DocVersionAutor", fields: [autorId], references: [id], onDelete: SetNull)
  autorNombre     String?
  aprobadorId     String?
  aprobador       Operator? @relation("DocVersionAprobador", fields: [aprobadorId], references: [id], onDelete: SetNull)
  aprobadorNombre String?
  fechaAprobacion DateTime?

  // Contenido
  motivoCambio      String? @db.Text
  notas             String? @db.Text
  hashDocumental    String? // SHA-256
  checklistTemplate Json?
  documentSnapshot  Json? // Almacena el estado completo del documento (titulo, descripcion, requerimientos, tags, etc.) al momento de crear la version

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Archivos asociados a esta versión
  files                  DocumentFile[]
  OrdenServicioDocumento OrdenServicioDocumento[]
  OSChecklist            OSChecklist[]
  trainings              TechnicianTraining[]
  prints                 DocumentPrint[]

  @@unique([documentId, versionMayor, versionMenor])
  @@index([documentId])
  @@index([estado])
}

model DocumentFile {
  id        String          @id @default(cuid())
  versionId String
  version   DocumentVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  nombreArchivo String
  tipoArchivo   String // application/pdf, image/jpeg, video/mp4, etc.
  tamanioBytes  Int     @default(0)
  url           String  @db.Text // URL o path al archivo
  esPrincipal   Boolean @default(false) // Archivo principal de la versión
  hashArchivo   String? // SHA-256 del archivo individual

  createdAt DateTime @default(now())

  @@index([versionId])
}

model DocumentReadConfirmation {
  id         String             @id @default(cuid())
  documentId String
  document   ControlledDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  operatorId       String
  operatorNombre   String
  confirmadoAt     DateTime @default(now())
  versionAlMomento String // "1.0" snapshot de la versión que leyó

  signatureId String?
  signature   DocumentSignatureAudit? @relation(fields: [signatureId], references: [SignatureID])

  @@unique([documentId, operatorId])
  @@index([documentId])
  @@index([operatorId])
}

model DocumentAlert {
  id         String             @id @default(cuid())
  documentId String
  document   ControlledDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  tipo               String // PROXIMA_REVISION | VENCIDO | CRITICO_EXPIRADO | SIN_ACTUALIZAR
  mensaje            String
  leido              Boolean @default(false)
  destinatarioId     String? // null = all supervisors/admins
  destinatarioNombre String?

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([tipo])
  @@index([leido])
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTEGRACIÓN QMS <-> FIELD SERVICE (ÓRDENES DE SERVICIO)
// ═══════════════════════════════════════════════════════════════════════════════

model DocumentApplicabilityRule {
  id         String             @id @default(cuid())
  documentId String
  document   ControlledDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  // Criterios de aplicación (si son null, aplican a todos en ese nivel)
  tipoActividad     String? // Match con Project.tipoActividad
  categoriaProyecto String? // Match con Project.categoria
  clienteId         String? // Match con Project.clientId
  nivelRiesgo       String? // bajo | medio | alto | critico
  tagsRequeridos    Json? // Lista de tags que el proyecto debe tener

  // Comportamiento al asignar
  bloqueanteDeInicio Boolean @default(false)
  requiereLecturaOS  Boolean @default(true)
  generaChecklist    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([documentId])
}

model DocumentPrint {
  id             String             @id @default(cuid())
  documentId     String
  document       ControlledDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  versionId      String
  version        DocumentVersion    @relation(fields: [versionId], references: [id], onDelete: Cascade)
  operatorId     String
  operator       Operator           @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  operatorNombre String
  fechaImpresion DateTime           @default(now())
  token          String             @unique // Encrypted/Hashed ID for the QR code

  createdAt DateTime @default(now())

  @@index([documentId])
  @@index([token])
}

model OrdenServicioDocumento {
  id              String        @id @default(cuid())
  ordenServicioId String
  ordenServicio   OrdenServicio @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)

  documentId String
  document   ControlledDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)
  versionId  String
  version    DocumentVersion    @relation(fields: [versionId], references: [id], onDelete: Restrict)

  versionSnapshot String // "1.2"
  requerido       Boolean @default(true)
  bloqueante      Boolean @default(false)

  // Seguimiento
  leido           Boolean  @default(false)
  fechaAsignacion DateTime @default(now())

  acknowledgements OSDocumentAcknowledgement[]

  @@unique([ordenServicioId, documentId])
  @@index([ordenServicioId])
  @@index([versionId])
}

model OSDocumentAcknowledgement {
  id            String                 @id @default(cuid())
  osDocumentoId String
  osDocumento   OrdenServicioDocumento @relation(fields: [osDocumentoId], references: [id], onDelete: Cascade)

  operatorId     String
  operator       Operator @relation(fields: [operatorId], references: [id], onDelete: Restrict)
  operatorNombre String

  fechaConfirmacion DateTime @default(now())
  gpsLat            Float?
  gpsLng            Float?
  ip                String?
  dispositivo       String?

  @@index([osDocumentoId])
  @@index([operatorId])
}

model OSChecklist {
  id              String        @id @default(cuid())
  ordenServicioId String
  ordenServicio   OrdenServicio @relation(fields: [ordenServicioId], references: [id], onDelete: Cascade)

  documentVersionId String? // La versión del procedimiento que originó este checklist
  version           DocumentVersion? @relation(fields: [documentVersionId], references: [id], onDelete: Restrict)

  titulo String
  estado String @default("pendiente") // pendiente | en_progreso | completado

  items OSChecklistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ordenServicioId])
}

model OSChecklistItem {
  id            String      @id @default(cuid())
  osChecklistId String
  osChecklist   OSChecklist @relation(fields: [osChecklistId], references: [id], onDelete: Cascade)

  descripcion       String
  esObligatorio     Boolean @default(false)
  requiereEvidencia Boolean @default(false)

  // Ejecución
  completado      Boolean   @default(false)
  observaciones   String?   @db.Text
  completadoPorId String?
  fechaCompletado DateTime?

  evidencias OSChecklistEvidence[]

  @@index([osChecklistId])
}

model OSChecklistEvidence {
  id                String          @id @default(cuid())
  osChecklistItemId String
  osChecklistItem   OSChecklistItem @relation(fields: [osChecklistItemId], references: [id], onDelete: Cascade)

  tipo        String // foto | video | firma
  urlArchivo  String  @db.Text
  observacion String? @db.Text

  gpsLat    Float?
  gpsLng    Float?
  createdAt DateTime @default(now())

  @@index([osChecklistItemId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// NEW QMS CHECKLIST ARCHITECTURE
// ═══════════════════════════════════════════════════════════════════════════════

model ChecklistTemplate {
  id                String   @id @default(cuid())
  code              String?  @unique
  name              String
  description       String?  @db.Text
  version           Int      @default(1)
  status            String   @default("active") // active | inactive
  checklistItems    Json     @default("[]") // JSON structure
  requiresEvidence  Boolean  @default(false)
  requiresPhotos    Boolean  @default(false)
  requiresSignature Boolean  @default(false)
  riskLevel         String   @default("low") // low | medium | high | critical
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tags TagChecklistTemplate[]
}

model TagChecklistTemplate {
  id                  String            @id @default(cuid())
  tagId               String
  tag                 ProjectTag        @relation(fields: [tagId], references: [id], onDelete: Cascade)
  checklistTemplateId String
  checklistTemplate   ChecklistTemplate @relation(fields: [checklistTemplateId], references: [id], onDelete: Cascade)
  createdAt           DateTime          @default(now())

  @@unique([tagId, checklistTemplateId])
  @@index([tagId])
  @@index([checklistTemplateId])
}

model DocumentChecklist {
  id         String              @id @default(cuid())
  projectId  String?
  project    Project?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  documentId String?
  document   ControlledDocument? @relation(fields: [documentId], references: [id], onDelete: Cascade)

  templateId      String
  templateVersion Int
  templateName    String
  snapshotData    Json // full JSON snapshot of checklistItems
  editable        Boolean @default(false)
  mandatory       Boolean @default(true)
  order           Int     @default(0)
  status          String  @default("pending") // pending | completed

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([documentId])
  @@index([templateId])
}

model TechnicianCompetency {
  id              String              @id @default(cuid())
  operatorId      String
  operator        Operator            @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  nombre          String // e.g. "Seguridad eléctrica", "Trabajo en altura", "Protocolo sanitario"
  documentId      String?
  document        ControlledDocument? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  estado          String              @default("pendiente") // pendiente | vigente | vencida | inactiva
  vencimiento     DateTime?
  evidencia       String?             @db.Text // Descripción o Base64 o URL
  evaluacion      String?             @db.Text // Nota o comentarios
  aprobadorId     String?
  aprobadorNombre String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([operatorId])
  @@index([documentId])
  @@index([estado])
}

model TechnicianTraining {
  id              String                  @id @default(cuid())
  operatorId      String
  operator        Operator                @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  documentId      String?
  document        ControlledDocument?     @relation(fields: [documentId], references: [id], onDelete: SetNull)
  versionId       String?
  version         DocumentVersion?        @relation(fields: [versionId], references: [id], onDelete: SetNull)
  titulo          String // Título de la capacitación
  estado          String                  @default("pendiente") // pendiente | en_progreso | aprobado | reprobado
  tipoContenido   String                  @default("video") // video | pdf | cuestionario | mixto
  urlContenido    String?                 @db.Text // URL externa, video embed o path
  cuestionario    Json? // Array de preguntas, opciones, y correcta
  respuestas      Json? // Array de respuestas del usuario
  puntaje         Float?
  puntajeMinimo   Float                   @default(70.0)
  tiempoInvertido Int? // En segundos
  fechaInicio     DateTime?
  fechaFin        DateTime?
  evaluadorId     String?
  evaluadorNombre String?
  observaciones   String?                 @db.Text
  signatureId     String?
  signature       DocumentSignatureAudit? @relation(fields: [signatureId], references: [SignatureID])
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([operatorId])
  @@index([documentId])
  @@index([versionId])
  @@index([estado])
}

// ═══════════════════════════════════════════════════════════════════════════════
// INTELIGENCIA ARTIFICIAL (GEMINI INTEGRATION)
// ═══════════════════════════════════════════════════════════════════════════════

model AiPrompt {
  id          String         @id @default(cuid())
  key         String         @unique // e.g. "ISO_DOC_GEN", "TECH_ASSISTANT", etc.
  name        String
  description String?
  template    String         @db.Text
  version     Int            @default(1)
  isActive    Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  logs        AiRequestLog[]
}

model AiRequestLog {
  id            String    @id @default(cuid())
  action        String // e.g. "GEN_ISO_DOC", "TECH_CHAT", "OCR", "GEN_CHECKLIST", "TRAINING_GEN", "SEMANTIC_SEARCH", "GEN_OBS", "IMAGE_ANOMALY"
  model         String // e.g. "gemini-2.5-flash", "gpt-4o", "claude-sonnet-4"
  provider      String    @default("gemini") // e.g. "gemini", "openai", "anthropic"
  promptKey     String?
  prompt        AiPrompt? @relation(fields: [promptKey], references: [key], onDelete: SetNull)
  promptVersion Int?

  // Usage tracking
  inputTokens   Int   @default(0)
  outputTokens  Int   @default(0)
  totalTokens   Int   @default(0)
  estimatedCost Float @default(0.0) // estimated cost in USD
  latencyMs     Int   @default(0)

  // Auditoria
  userId   String?
  userName String?
  userRole String?
  entity   String? // e.g. "ControlledDocument", "OrdenServicio", "Project"
  entityId String?

  // Payload (sanitized or status)
  success      Boolean @default(true)
  errorMessage String? @db.Text

  createdAt DateTime @default(now())

  @@index([action])
  @@index([userId])
  @@index([createdAt])
}

model AiConversation {
  id        String                  @id @default(cuid())
  userId    String
  entity    String? // e.g. "OrdenServicio", "Project", "Tool"
  entityId  String?
  title     String                  @default("Conversación técnica")
  messages  AiConversationMessage[]
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  @@index([userId])
  @@index([entity, entityId])
}

model AiConversationMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // "user" | "model"
  content        String         @db.Text
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

model ExternalCertificate {
  id           String   @id @default(cuid())
  operatorId   String
  operator     Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  nombreCurso  String
  institucion  String
  descripcion  String?  @db.Text
  horas        Float?
  fechaEmision String? // YYYY-MM-DD
  estado       String   @default("pendiente") // pendiente | aprobado | rechazado
  archivoUrl   String?  @db.Text
  aiData       Json? // To store AI extraction details like hours, dates, entities
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([operatorId])
}

model SafetyAudit {
  id              String   @id @default(cuid())
  operatorId      String
  operator        Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  fecha           String // YYYY-MM-DD
  eppAprobado     Boolean  @default(true)
  lotoAplicado    Boolean  @default(true)
  cumpleNormativa Boolean  @default(true)
  observaciones   String?  @db.Text
  createdAt       DateTime @default(now())

  @@index([operatorId])
}

model Sugerencia {
  id                  String                 @id @default(cuid())
  fecha_creacion      DateTime               @default(now())
  fecha_actualizacion DateTime               @default(now()) @updatedAt
  tipo_registro       String
  titulo              String
  descripcion         String                 @db.Text
  area_involucrada    String
  beneficios          Json                   @default("[]")
  impacto_estimado    String
  propuesta_solucion  String?                @db.Text
  frecuencia_problema String?
  presentacion        String // "anonima" | "identificada"
  usuario_id          String?
  usuario             Operator?              @relation("SugerenciaAutor", fields: [usuario_id], references: [id], onDelete: SetNull)
  responsable_id      String?
  responsable         Operator?              @relation("SugerenciaResponsable", fields: [responsable_id], references: [id], onDelete: SetNull)
  fecha_cierre        DateTime?
  reunion_programada  DateTime?
  notas_resolucion    String?                @db.Text
  estado              String                 @default("Pendiente") // Pendiente | En evaluación | Aprobada | Rechazada | Implementada | Cerrada
  archivos_adjuntos   Json                   @default("[]") // [{nombre, url, size}]
  historial           SugerenciaHistorial[]
  comentarios         SugerenciaComentario[]
  acciones            AccionMejora[]
  analisis_ia         Json? // AI analysis result (cached)

  @@index([usuario_id])
  @@index([responsable_id])
  @@index([estado])
}

model SugerenciaHistorial {
  id             String     @id @default(cuid())
  sugerenciaId   String
  sugerencia     Sugerencia @relation(fields: [sugerenciaId], references: [id], onDelete: Cascade)
  estadoAnterior String
  estadoNuevo    String
  usuario        String // Nombre del usuario/sistema
  fecha          DateTime   @default(now())

  @@index([sugerenciaId])
}

model SugerenciaComentario {
  id           String     @id @default(cuid())
  sugerenciaId String
  sugerencia   Sugerencia @relation(fields: [sugerenciaId], references: [id], onDelete: Cascade)
  autor        String // Nombre del autor
  texto        String     @db.Text
  fecha        DateTime   @default(now())

  @@index([sugerenciaId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// GESTIÓN DE NO CONFORMIDADES Y CAPA (ISO 9001:2015)
// ═══════════════════════════════════════════════════════════════════════════════

model NoConformidad {
  id               String   @id @default(cuid())
  codigoNC         String?  @unique
  fechaDeteccion   DateTime
  fechaRegistro    DateTime @default(now())
  origen           String // Auditoría interna, Reclamo de cliente, etc.
  tipoNC           String // Mayor, Menor, etc.
  categoria        String
  etiquetas        Json     @default("[]")
  descripcion      String   @db.Text
  evidenciaAdjunta Json     @default("[]")
  procesoAfectado  String?
  areaAfectada     String?

  responsableRegistroId String?
  responsableRegistro   Operator? @relation("NCResponsableRegistro", fields: [responsableRegistroId], references: [id])

  responsablesTratamiento Operator[] @relation("NCResponsableTratamiento")

  estado          String    @default("Abierta")
  criticidad      String    @default("Media")
  impacto         String?
  fechaCompromiso DateTime?
  fechaCierre     DateTime?
  resultadoFinal  String?   @db.Text
  observaciones   String?   @db.Text
  embedding       Json? // Vector de embedding de la NC para búsqueda semántica

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  analisisCausaRaiz      AnalisisCausaRaiz[]
  accionesMejora         AccionMejora[]
  verificacionesEficacia VerificacionEficacia[]
  reuniones              ReunionNC[]
  documentacionAfectada  DocumentacionAfectada[]
  capacitacionesReq      CapacitacionRequerida[]
}

model AnalisisCausaRaiz {
  id                  String        @id @default(cuid())
  ncId                String
  noConformidad       NoConformidad @relation(fields: [ncId], references: [id], onDelete: Cascade)
  metodologia         String // 5 Porqués, Ishikawa, etc.
  descripcionAnalisis String        @db.Text
  descripcion         String?       @db.Text
  causaInmediata      String?       @db.Text
  causaBasica         String?       @db.Text
  causaRaiz           String?       @db.Text

  participantes Json?     @default("[]")
  fechaAnalisis DateTime? @default(now())

  responsableId String?
  responsable   Operator? @relation(fields: [responsableId], references: [id])
  fecha         DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ncId])
}

model VerificacionEficacia {
  id            String         @id @default(cuid())
  ncId          String?
  noConformidad NoConformidad? @relation(fields: [ncId], references: [id], onDelete: Cascade)

  accionMejoraId String?
  accionMejora   AccionMejora? @relation(fields: [accionMejoraId], references: [id], onDelete: Cascade)

  responsableVerificacionId String?
  responsableVerificacion   Operator? @relation(fields: [responsableVerificacionId], references: [id])
  fechaVerificacion         DateTime
  resultado                 String    @db.Text
  observaciones             String?   @db.Text
  eficaz                    Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ncId])
  @@index([accionMejoraId])
}

model ReunionNC {
  id            String        @id @default(cuid())
  ncId          String
  noConformidad NoConformidad @relation(fields: [ncId], references: [id], onDelete: Cascade)
  fecha         DateTime
  participantes Json          @default("[]")
  agenda        String?       @db.Text
  acta          String?       @db.Text
  compromisos   Json          @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ncId])
}

model DocumentacionAfectada {
  id            String        @id @default(cuid())
  ncId          String
  noConformidad NoConformidad @relation(fields: [ncId], references: [id], onDelete: Cascade)

  documentoId  String?
  documento    ControlledDocument? @relation(fields: [documentoId], references: [id])
  documentoRef String? // For reference when ControlledDocument is not available

  tipoRelacion String // Documento incumplido, modificado, obsoleto, nuevo documento

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ncId])
  @@index([documentoId])
}

model CapacitacionRequerida {
  id            String        @id @default(cuid())
  ncId          String
  noConformidad NoConformidad @relation(fields: [ncId], references: [id], onDelete: Cascade)

  capacitacion     String
  motivo           String    @db.Text
  personalAfectado Json      @default("[]") // Array of Operator IDs or Names
  fechaProgramada  DateTime?
  fechaRealizacion DateTime?
  estado           String    @default("Pendiente")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ncId])
}

model AccionMejora {
  id                String  @id @default(cuid())
  codigoAccion      String? @unique
  tipoAccion        String  @default("Mejora Continua") // Correctiva, Preventiva, Mejora Continua, Mitigación de Riesgo
  origen            String  @default("Otro") // No Conformidad, Riesgo, Auditoría Interna, etc.
  descripcion       String  @db.Text
  justificacion     String? @db.Text
  beneficioEsperado String? @db.Text

  responsableId String?
  responsable   Operator? @relation(fields: [responsableId], references: [id], onDelete: SetNull)

  prioridad        String    @default("Media") // Baja, Media, Alta
  fechaCreacion    DateTime  @default(now())
  fechaInicio      DateTime?
  fechaCompromiso  DateTime?
  fechaCierre      DateTime?
  porcentajeAvance Float     @default(0)
  estado           String    @default("Pendiente") // Pendiente, En Progreso, Completada, Cerrada, Cancelada
  eficacia         String? // Pendiente, Eficaz, Ineficaz
  evidencia        String?   @db.Text
  observaciones    String?   @db.Text

  // Relaciones opcionales para trazabilidad
  ncId          String?
  noConformidad NoConformidad? @relation(fields: [ncId], references: [id])

  sugerenciaId String?
  sugerencia   Sugerencia? @relation(fields: [sugerenciaId], references: [id], onDelete: Cascade)

  riesgoId String?
  riesgo   Riesgo? @relation(fields: [riesgoId], references: [id])

  oportunidadId String?
  oportunidad   Oportunidad? @relation(fields: [oportunidadId], references: [id])

  objetivoId String?
  objetivo   ObjetivoCalidad? @relation(fields: [objetivoId], references: [id])

  auditoriaId      String?
  documentoId      String?
  capacitacionId   String?
  proyectoMejoraId String?

  verificaciones VerificacionEficacia[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([ncId])
  @@index([sugerenciaId])
  @@index([responsableId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// RIESGOS, OBJETIVOS Y OPORTUNIDADES
// ═══════════════════════════════════════════════════════════════════════════════

model Riesgo {
  id                  String    @id @default(cuid())
  codigo              String?   @unique
  titulo              String
  descripcion         String    @db.Text
  categoria           String
  probabilidad        String    @default("Media") // Baja, Media, Alta
  impacto             String    @default("Medio") // Bajo, Medio, Alto, Crítico
  nivelRiesgo         String    @default("Medio") // Calculado
  estado              String    @default("Identificado") // Identificado, En Tratamiento, Mitigado, Aceptado, Cerrado
  procesoAfectado     String?
  responsableId       String?
  fechaIdentificacion DateTime  @default(now())
  fechaRevision       DateTime?

  accionesMejora AccionMejora[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ObjetivoCalidad {
  id                 String    @id @default(cuid())
  codigo             String?   @unique
  titulo             String
  descripcion        String    @db.Text
  indicador          String
  meta               String
  unidad             String?
  frecuenciaMedicion String?
  responsableId      String?
  estado             String    @default("Activo") // Activo, Cumplido, No Cumplido, En Revisión
  periodo            String?
  fechaInicio        DateTime?
  fechaFin           DateTime?
  resultadoActual    String?

  accionesMejora AccionMejora[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Oportunidad {
  id                  String   @id @default(cuid())
  codigo              String?  @unique
  titulo              String
  descripcion         String   @db.Text
  tipoOportunidad     String
  beneficioEsperado   String?  @db.Text
  estado              String   @default("Identificada") // Identificada, En Evaluación, Aprobada, Implementada, Descartada
  responsableId       String?
  fechaIdentificacion DateTime @default(now())

  accionesMejora AccionMejora[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════════════════════════════════════
// CENTRO DE AYUDA Y CAPACITACIÓN SGI
// ═══════════════════════════════════════════════════════════════════════════════

model HelpCategory {
  id          String        @id @default(cuid())
  slug        String        @unique
  title       String
  description String?
  iconName    String        @default("BookOpen")
  order       Int           @default(0)
  active      Boolean       @default(true)
  articles    HelpArticle[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HelpArticle {
  id         String       @id @default(cuid())
  slug       String       @unique
  categoryId String
  category   HelpCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  title       String
  description String @db.Text
  content     String @db.Text

  objetivo        String? @db.Text
  comoAcceder     String? @db.Text
  buenasPracticas String? @db.Text

  roles          Json @default("[]")
  relatedModules Json @default("[]")

  order       Int     @default(0)
  isPublished Boolean @default(true)

  viewsCount   Int @default(0)
  helpfulCount Int @default(0)

  tags HelpTag[]
  faqs HelpFaq[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([slug])
}

model HelpTag {
  id       String        @id @default(cuid())
  name     String        @unique
  articles HelpArticle[]
}

model HelpFaq {
  id        String      @id @default(cuid())
  articleId String
  article   HelpArticle @relation(fields: [articleId], references: [id], onDelete: Cascade)
  question  String
  answer    String      @db.Text
  order     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([articleId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// TAREAS — Planificación y Recordatorios
// ═══════════════════════════════════════════════════════════════════════════════

model Tarea {
  id          String  @id @default(cuid())
  titulo      String
  descripcion String? @db.Text
  estado      String  @default("pendiente")
  // pendiente | en_progreso | completada | cancelada
  prioridad   String  @default("media")
  // baja | media | alta | urgente
  categoria   String?

  // Fechas
  fechaInicio      DateTime?
  fechaVencimiento DateTime?
  fechaCompletada  DateTime?

  // Relación con proyecto (opcional)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  // Creador
  creadorId     String
  creadorNombre String

  // Involucrados (many-to-many via tabla intermedia)
  involucrados TareaInvolucrado[]

  // Recordatorios
  recordatorios TareaRecordatorio[]

  // Notas/comentarios inline
  notas       String?           @db.Text
  comentarios TareaComentario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([estado])
  @@index([projectId])
  @@index([creadorId])
  @@index([fechaVencimiento])
}

model TareaInvolucrado {
  id         String   @id @default(cuid())
  tareaId    String
  tarea      Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  rol        String   @default("responsable")
  // responsable | colaborador | observador

  @@unique([tareaId, operatorId])
  @@index([tareaId])
  @@index([operatorId])
}

model TareaRecordatorio {
  id      String @id @default(cuid())
  tareaId String
  tarea   Tarea  @relation(fields: [tareaId], references: [id], onDelete: Cascade)

  tipo         String   @default("unico")
  // unico | diario | semanal
  fechaDisparo DateTime
  mensaje      String?

  // cron-job.org integration
  cronJobId     Int? // ID returned by cron-job.org API
  cronJobActivo Boolean @default(true)

  disparado      Boolean   @default(false)
  fechaDisparado DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tareaId])
  @@index([fechaDisparo])
}

model TareaComentario {
  id         String   @id @default(cuid())
  tareaId    String
  tarea      Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  operatorId String
  operator   Operator @relation(fields: [operatorId], references: [id], onDelete: Cascade)
  mensaje    String   @db.Text
  createdAt  DateTime @default(now())

  @@index([tareaId])
  @@index([operatorId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// ADMINISTRACIÓN Y GASTOS
// ═══════════════════════════════════════════════════════════════════════════════

model Proveedor {
  id             String           @id @default(cuid())
  razonSocial    String
  nombreFantasia String?
  cuit           String           @unique
  condicionIva   String?
  domicilio      String?          @db.Text
  activo         Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  facturas       FacturaConsumo[]
}

model CodigoGasto {
  id          String           @id @default(cuid())
  codigo      String           @unique
  descripcion String
  activo      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  facturas    FacturaConsumo[]
}

model FacturaConsumo {
  id                String       @id @default(cuid())
  fechaEmision      DateTime
  fechaVencimiento  DateTime?
  proveedorId       String
  proveedor         Proveedor    @relation(fields: [proveedorId], references: [id], onDelete: Restrict)
  codigoGastoId     String?
  codigoGasto       CodigoGasto? @relation(fields: [codigoGastoId], references: [id], onDelete: SetNull)
  descripcion       String?      @db.Text
  tipoComprobante   String?
  letraComprobante  String?
  puntoVenta        String?
  numeroComprobante String?

  // Importes
  netoGeneral       Float  @default(0) // subtotal o neto sin iva especifico
  neto21            Float  @default(0)
  neto10_5          Float  @default(0)
  neto27            Float  @default(0)
  iva21             Float  @default(0)
  iva10_5           Float  @default(0)
  iva27             Float  @default(0)
  noGravados        Float  @default(0)
  percepcionesIva   Float  @default(0)
  percepcionesIibb  Float  @default(0)
  impuestosInternos Float  @default(0)
  otrosImpuestos    Float  @default(0)
  total             Float  @default(0)
  moneda            String @default("ARS")

  cae                 String?
  fechaVencimientoCae DateTime?

  // Datos IA
  esFactura         Boolean @default(true)
  statusIaConfianza Float?
  iaRawData         Json? // Guarda el JSON original que devolvió Gemini

  // Archivo
  archivoUrl String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([proveedorId])
  @@index([codigoGastoId])
  @@index([fechaEmision])
}

// ═══════════════════════════════════════════════════════════════════════════════
// FIRMAS ELECTRÓNICAS (ISO 9001)
// ═══════════════════════════════════════════════════════════════════════════════

model DocumentSignatureAudit {
  SignatureID        String   @id
  DocumentID         String
  DocumentVersion    String
  UserID             String
  UserName           String
  DNI                String
  DeviceID           String
  IPAddress          String
  SignedAtUTC        DateTime @default(now())
  HashSignature      String
  VerificationStatus String   @default("VALIDA")
  VerifiedAtUTC      DateTime @default(now())
  VerifiedBy         String?

  documentReadConfirmations DocumentReadConfirmation[]
  technicianTrainings       TechnicianTraining[]

  @@index([DocumentID])
  @@index([UserID])
  @@index([VerificationStatus])
}

// ═══════════════════════════════════════════════════════════════════════════════
// GESTIÓN DE OKR Y KPI (ISO 9001:2015 – Medición, Seguimiento y Mejora)
// ═══════════════════════════════════════════════════════════════════════════════

model Okr {
  id                 String    @id @default(uuid())
  codigoOkr          String    @unique // OKR-001
  nombre             String
  descripcion        String?   @db.Text
  areaResponsable    String?
  responsableId      String?
  responsable        Operator? @relation("OkrResponsable", fields: [responsableId], references: [id])
  fechaInicio        DateTime?
  fechaFin           DateTime?
  frecuenciaRevision String? // Mensual, Trimestral, Semestral, Anual
  metaGlobal         String?   @db.Text
  estado             String    @default("Activo") // Activo | Cerrado | Cancelado
  observaciones      String?   @db.Text

  // Cumplimiento calculado
  porcentajeAvance   Float  @default(0)
  estadoCumplimiento String @default("Sin datos") // Verde | Amarillo | Rojo | Sin datos

  // Trazabilidad ISO 9001
  fechaCreacion         DateTime @default(now())
  usuarioCreacionId     String?
  fechaModificacion     DateTime @updatedAt
  usuarioModificacionId String?

  kpis Kpi[]

  @@index([estado])
  @@index([responsableId])
}

model Kpi {
  id                   String    @id @default(uuid())
  codigoKpi            String    @unique // KPI-001
  okrId                String
  okr                  Okr       @relation(fields: [okrId], references: [id], onDelete: Restrict)
  nombre               String
  descripcion          String?   @db.Text
  formulaCalculo       String?   @db.Text
  unidadMedida         String?
  valorObjetivo        Float
  valorMinimoAceptable Float?
  valorMaximoEsperado  Float?
  frecuenciaMedicion   String? // Diario | Semanal | Mensual | Trimestral | Semestral | Anual
  responsableCargaId   String?
  responsableCarga     Operator? @relation("KpiResponsableCarga", fields: [responsableCargaId], references: [id])
  fuenteDatos          String?
  estado               String    @default("Activo") // Activo | Inactivo

  // Tipo de registro y fuente de datos
  tipoRegistro       String   @default("Manual") // Manual | Dataset
  datasetId          String?
  dataset            Dataset? @relation("KpiDataset", fields: [datasetId], references: [id], onDelete: SetNull)
  campoValor         String?  // Columna del resultado del Dataset a usar como valor
  funcionAgregacion   String?  // SUM | AVG | COUNT | MIN | MAX | LAST | null

  // Cumplimiento calculado (snapshot del último registro)
  ultimoValor        Float?
  estadoCumplimiento String? // Cumple | En Riesgo | No Cumple

  // Trazabilidad ISO 9001
  fechaCreacion         DateTime @default(now())
  usuarioCreacionId     String?
  fechaModificacion     DateTime @updatedAt
  usuarioModificacionId String?

  historico    KpiHistorico[]
  planesAccion PlanAccionKpi[]

  @@index([okrId])
  @@index([estado])
  @@index([responsableCargaId])
  @@index([datasetId])
}

model KpiHistorico {
  id                    String   @id @default(uuid())
  kpiId                 String
  kpi                   Kpi      @relation(fields: [kpiId], references: [id], onDelete: Restrict)
  fechaMedicion         DateTime
  valorObtenido         Float
  comentario            String?  @db.Text
  usuarioRegistroId     String?
  usuarioRegistroNombre String?

  createdAt DateTime @default(now())

  @@index([kpiId])
  @@index([fechaMedicion])
}

model GraficoConfig {
  id            String  @id @default(uuid())
  codigoGrafico String  @unique // GRF-001
  nombre        String
  descripcion   String? @db.Text
  tipoGrafico   String // Linea | Barra | Gauge | Indicador | Torta
  vistaOrigen   String? // Identificador de la fuente de datos (legacy)
  configuracion Json? // Configuración personalizada del gráfico (colores, ejes, etc.)
  estado        String  @default("Activo") // Activo | Inactivo

  // Fuente de datos desde Dataset
  datasetId     String?
  dataset       Dataset? @relation("GraficoDataset", fields: [datasetId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([datasetId])
}

model PlanAccionKpi {
  id               String    @id @default(uuid())
  kpiId            String
  kpi              Kpi       @relation(fields: [kpiId], references: [id], onDelete: Restrict)
  descripcion      String    @db.Text
  causa            String?   @db.Text
  accionCorrectiva String?   @db.Text
  responsableId    String?
  responsable      Operator? @relation("PlanAccionKpiResponsable", fields: [responsableId], references: [id])
  fechaCompromiso  DateTime?
  fechaCierre      DateTime?
  estado           String    @default("Pendiente") // Pendiente | En Curso | Cerrado

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kpiId])
  @@index([estado])
  @@index([responsableId])
}

// ═══════════════════════════════════════════════════════════════════════════════
// MOTOR DE DATASETS Y DICCIONARIO DE DATOS
// ═══════════════════════════════════════════════════════════════════════════════

model DiccionarioTabla {
  id                  String   @id @default(uuid())
  nombreTabla         String   @unique
  descripcion         String?  @db.Text
  cantidadRegistros   Int      @default(0)
  ultimaActualizacion DateTime?
  oculta              Boolean  @default(false)

  campos DiccionarioCampo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DiccionarioCampo {
  id              String           @id @default(uuid())
  tablaId         String
  tabla           DiccionarioTabla @relation(fields: [tablaId], references: [id], onDelete: Cascade)
  nombreCampo     String
  tipoDato        String
  longitud        Int?
  permiteNulos    Boolean          @default(true)
  esClavePrimaria Boolean          @default(false)
  esClaveForanea  Boolean          @default(false)
  referenciaTabla String?
  referenciaCampo String?
  descripcion     String?          @db.Text
  ejemploValor    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tablaId, nombreCampo])
  @@index([tablaId])
}

model Dataset {
  id            String    @id @default(uuid())
  codigoDataset String    @unique // DS-001
  nombre        String
  descripcion   String?   @db.Text
  responsableId String?
  responsable   Operator? @relation("DatasetResponsable", fields: [responsableId], references: [id])
  estado        String    @default("Activo") // Activo | Inactivo | Error
  habilitado    Boolean   @default(true)

  // Definición de la consulta
  modoConsulta     String  @default("SQL") // SQL | Visual
  consultaSQL      String? @db.Text
  definicionVisual Json?

  // Variables dinámicas
  variables Json? @default("[]")

  // Ejecución programada
  tipoEjecucion    String    @default("Manual") // Manual | Programada
  cronExpresion    String?
  frecuencia       String?   // Cada hora | Diario | Semanal | Mensual | Personalizada
  horaEjecucion    String?
  zonaHoraria      String?   @default("America/Argentina/Buenos_Aires")
  proximaEjecucion DateTime?
  ultimaEjecucion  DateTime?
  timeoutSegundos  Int       @default(30)
  limiteRegistros  Int       @default(10000)

  // Resultado cacheado
  ultimoResultado Json?
  ultimoSchema    Json?

  // Trazabilidad
  fechaCreacion     DateTime @default(now())
  fechaModificacion DateTime @updatedAt
  usuarioCreacionId String?

  historico       DatasetEjecucion[]
  kpisAsociados   Kpi[]            @relation("KpiDataset")
  graficosAsociados GraficoConfig[] @relation("GraficoDataset")

  @@index([estado])
  @@index([responsableId])
  @@index([tipoEjecucion])
}

model DatasetEjecucion {
  id                String   @id @default(uuid())
  datasetId         String
  dataset           Dataset  @relation(fields: [datasetId], references: [id], onDelete: Cascade)
  fechaEjecucion    DateTime @default(now())
  duracionMs        Int      @default(0)
  cantidadRegistros Int      @default(0)
  estado            String   @default("Exitosa") // Exitosa | Error | Timeout | Cancelada
  mensajeError      String?  @db.Text
  consultaEjecutada String?  @db.Text
  usuarioId         String?
  tipo              String   @default("Manual") // Manual | Programada

  createdAt DateTime @default(now())

  @@index([datasetId])
  @@index([fechaEjecucion])
  @@index([estado])
}
